# ============================================================================
# GeoTerrain Split Architecture — .gitignore
# Only GeoTerrainBridge/ and GeoTerrainStudio/ remain in this repo.
# ============================================================================

# ─── GeoTerrainStudio (Electron + React + TypeScript) ──────────────────────

# Dependencies
GeoTerrainStudio/node_modules/
GeoTerrainStudio/.pnpm-store/

# Build output
GeoTerrainStudio/dist/
GeoTerrainStudio/dist-electron/
GeoTerrainStudio/release/
GeoTerrainStudio/out/

# Native addon build
GeoTerrainStudio/electron/native/build/
GeoTerrainStudio/electron/native/*.node
GeoTerrainStudio/electron/native/**/*.obj
GeoTerrainStudio/electron/native/**/*.pdb
GeoTerrainStudio/electron/native/**/*.ilk

# Vite / TS cache
GeoTerrainStudio/.vite/
GeoTerrainStudio/*.tsbuildinfo

# Logs
GeoTerrainStudio/npm-debug.log*
GeoTerrainStudio/yarn-debug.log*
GeoTerrainStudio/yarn-error.log*
GeoTerrainStudio/pnpm-debug.log*

# OS / IDE
GeoTerrainStudio/.DS_Store
GeoTerrainStudio/Thumbs.db

# ─── GeoTerrainBridge (C++ Qt UNIGINE Plugin) ──────────────────────────────

# CMake / build
GeoTerrainBridge/build/
GeoTerrainBridge/build_bridge/
GeoTerrainBridge/CMakeCache.txt
GeoTerrainBridge/CMakeFiles/
GeoTerrainBridge/cmake_install.cmake
GeoTerrainBridge/Makefile
GeoTerrainBridge/install_manifest.txt
GeoTerrainBridge/CTestTestfile.cmake
GeoTerrainBridge/_deps/

# Compiled binaries
GeoTerrainBridge/**/*.dll
GeoTerrainBridge/**/*.exe
GeoTerrainBridge/**/*.lib
GeoTerrainBridge/**/*.exp
GeoTerrainBridge/**/*.pdb
GeoTerrainBridge/**/*.ilk
GeoTerrainBridge/**/*.obj
GeoTerrainBridge/**/*.o

# Qt MOC / autogen
GeoTerrainBridge/**/*_autogen/
GeoTerrainBridge/**/moc_*.cpp
GeoTerrainBridge/**/moc_*.h
GeoTerrainBridge/**/qrc_*.cpp
GeoTerrainBridge/**/ui_*.h

# ─── Shared / Global ────────────────────────────────────────────────────────

# Terrain data (large GeoTIFFs, never commit)
*.tif
*.tiff
*.r16
*.raw
*.exr
*.lmap
*.heightmap

# Export folders
GeoTerrainExport/
GatheredExport/
*.terrain/

# IDE
.vs/
.idea/
*.user
*.suo
*.sdf
*.opensdf
*.VC.db
*.VC.opendb
*.vcxproj.user
.vscode/

# OS
Thumbs.db
Desktop.ini
.DS_Store

# Logs
*.log

# Temporary files
*.tmp
*.temp
*.swp
*.swo
*~
node_modules
